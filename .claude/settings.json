{
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(uv run *)",
      "Bash(make test *)"
    ]
  },
  "mcpServers": {
    "ze-eval": {
      "command": "uv",
      "args": ["run", "python", "evals/mcp_server.py"],
      "env": {
        "ZE_EVAL_URL": "http://localhost:8000",
        "ZE_API_KEY": ""
      }
    }
  }
}
